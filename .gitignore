# api-manager runtime state — must never be committed
# (the actual state lives in ~/.api-manager/ anyway, but be safe)
.api-manager/
metadata.json
audit.db
backups/

# Env files — the tool manages these, they should NEVER live in this repo
.env
.env.*
!.env.example

# Don't commit screenshots or recordings from local testing
screenshots/*.local.*
*.mov.local
